# 基础环境标识，用来决定叠加加载 .env.local / .env.test / .env.prod
APP_ENV=local

# 启动端口
SERVER_HOST=0.0.0.0
SERVER_PORT=5100

APP_NAME=FastAPI Mall Enterprise Starter
APP_DEBUG=true
APP_VERSION=0.1.0
APP_SECRET_KEY=change-this-secret-key
APP_TIMEZONE=Asia/Shanghai
APP_API_PREFIX=/api

CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=false
LOG_LEVEL=INFO
LOG_FORMAT=pretty
SQL_ECHO=false

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=mall_enterprise
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Woshi110

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

WECHAT_MINIAPP_APPID=replace-me
WECHAT_MINIAPP_SECRET=replace-me
WECHAT_MCH_ID=replace-me
WECHAT_MCH_API_V3_KEY=replace-me
WECHAT_NOTIFY_URL=https://example.com/api/open/v1/pay/wechat/callback

SMS_PROVIDER=mock
STORAGE_PROVIDER=mock
PUSH_PROVIDER=mock
